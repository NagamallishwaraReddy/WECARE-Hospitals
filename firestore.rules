rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only read and write their own profile data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Users can create appointments and manage their own appointments
    match /appointments/{appointmentId} {
      // Allow creation if the user is authenticated and is setting themselves as the owner
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Allow reads and updates only if the appointment belongs to the requesting user
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
